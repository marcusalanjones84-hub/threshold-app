# Environment Variables for THRESHOLD

# Supabase (Replace with your actual Supabase credentials)
REACT_APP_SUPABASE_URL=your_supabase_url
REACT_APP_SUPABASE_ANON_KEY=your_supabase_anon_key

# Stripe (Replace with your actual Stripe credentials)
REACT_APP_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
REACT_APP_STRIPE_PRO_MONTHLY_PRICE_ID=price_xxx
REACT_APP_STRIPE_PRO_ANNUAL_PRICE_ID=price_xxx
REACT_APP_STRIPE_COMPLETE_PRICE_ID=price_xxx

# OneSignal Push Notifications (Optional - works in mock mode without)
# Get your App ID from: https://onesignal.com/
REACT_APP_ONESIGNAL_APP_ID=your_onesignal_app_id
